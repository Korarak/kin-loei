{
  "permissions": {
    "allow": [
      "Bash(xargs wc:*)",
      "Bash(xargs ls:*)",
      "Bash(docker compose:*)",
      "Bash(npm run:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:8000/health\")",
      "Bash(curl -s \"http://localhost:8000/openapi.json\")",
      "Bash(docker ps:*)",
      "Bash(docker exec:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3000/admin/dashboard\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3000/admin/users\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3000/admin/organization\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3000/admin/import\")",
      "Bash(npm create *)",
      "Bash(npm install *)",
      "Bash(curl *)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
